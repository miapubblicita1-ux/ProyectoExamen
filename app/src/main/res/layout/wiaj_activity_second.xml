<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="Segunda Pantalla"
        android:textSize="20sp" />

    <EditText
        android:id="@+id/wiaj_et_nombre_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre"
        android:enabled="true" />

    <EditText
        android:id="@+id/wiaj_et_apellidos_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Apellidos"
        android:enabled="true" />

    <EditText
        android:id="@+id/wiaj_et_dividendo_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Dividendo"
        android:enabled="false" />

    <EditText
        android:id="@+id/wiaj_et_divisor_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Divisor"
        android:enabled="false" />

    <EditText
        android:id="@+id/wiaj_et_numero_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Numero"
        android:enabled="false" />

    <Button
        android:id="@+id/wiaj_btn_siguiente_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Siguiente"
        android:enabled="true" />

    <Button
        android:id="@+id/wiaj_btn_cerrar_second"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar"
        android:enabled="false" />

</LinearLayout>